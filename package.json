{
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:api": "python3 -m uvicorn backend.main:app --host 127.0.0.1 --port 8000",
    "dev:api:payment-sim": "WORLD_CUP_PAYMENT_SIMULATION=1 WORLD_CUP_PUBLIC_API_BASE_URL=http://127.0.0.1:8000 WORLD_CUP_PUBLIC_WEB_BASE_URL=http://127.0.0.1:5173 python3 -m uvicorn backend.main:app --host 127.0.0.1 --port 8000",
    "test:model": "PYTHONWARNINGS=ignore::DeprecationWarning python3 -m unittest discover -s tests",
    "test:payments:simulated": "python3 scripts/simulate_payment_flows.py",
    "validate:data": "python3 scripts/validate_prediction_data.py",
    "import:tournament-data": "python3 scripts/import_tournament_data.py",
    "import:history": "python3 scripts/import_team_match_history.py",
    "import:news-feed": "python3 scripts/import_news_feed.py",
    "public:data:update": "python3 scripts/run_public_data_pipeline.py --config backend/data_files/public-data-sources.json",
    "review:news": "python3 scripts/review_news_item.py",
    "daily:update": "python3 scripts/run_daily_update.py --feed-config backend/data_files/daily-feed-sources.json --score-config backend/data_files/score-sources.json",
    "daily:update:production": "npm run public:data:update && python3 scripts/run_daily_update.py --score-config backend/data_files/score-sources.json --simulations 50000 && npm run report:model-quality",
    "daily:check": "python3 scripts/check_daily_update_health.py",
    "production:check": "python3 scripts/check_production_readiness.py",
    "production:serve": "WORLD_CUP_SERVE_STATIC=1 python3 -m uvicorn backend.main:app --host 0.0.0.0 --port ${PORT:-8000} --workers ${WORLD_CUP_API_WORKERS:-2}",
    "update:snapshot": "python3 scripts/update_prediction_snapshot.py",
    "report:model-quality": "python3 scripts/write_model_quality_report.py",
    "deploy:api": "npm run update:snapshot && bash scripts/deploy-cloudflare-api.sh",
    "deploy:web": "VITE_API_BASE_URL=https://world-cup-prediction-api.loveice0624.workers.dev npm run build && npx wrangler pages deploy dist --project-name world-cup-prediction-system --branch main",
    "deploy:admin": "VITE_FORCE_ADMIN=1 VITE_API_BASE_URL=https://world-cup-prediction-api.loveice0624.workers.dev npm run build && npx wrangler pages deploy dist --project-name world-cup-prediction-admin --branch main",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "lucide-react": "^1.18.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3"
  }
}
