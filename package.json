{
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:api": "python3 -m uvicorn backend.main:app --host 127.0.0.1 --port 8000",
    "test:model": "PYTHONWARNINGS=ignore::DeprecationWarning python3 -m unittest discover -s tests",
    "validate:data": "python3 scripts/validate_prediction_data.py",
    "import:tournament-data": "python3 scripts/import_tournament_data.py",
    "import:news-feed": "python3 scripts/import_news_feed.py",
    "review:news": "python3 scripts/review_news_item.py",
    "daily:update": "python3 scripts/run_daily_update.py --feed-config backend/data_files/daily-feed-sources.json --score-config backend/data_files/score-sources.json",
    "daily:check": "python3 scripts/check_daily_update_health.py",
    "update:snapshot": "python3 scripts/update_prediction_snapshot.py",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3"
  }
}
